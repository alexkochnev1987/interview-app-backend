# Copy to .env.lightsail on the Lightsail instance and fill real values.

# Public URLs
API_DOMAIN=api.example.com
FRONTEND_URL=https://example.com
GOOGLE_CALLBACK_URL=https://api.example.com/auth/google/callback

# Backend
NODE_ENV=production
PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://interview_app:replace-db-password@postgres:5432/interview_app_prod

# Postgres container bootstrap values.
# Keep POSTGRES_PASSWORD in sync with DATABASE_URL.
POSTGRES_DB=interview_app_prod
POSTGRES_USER=interview_app
POSTGRES_PASSWORD=replace-db-password

# S3 storage for interview media and database backups.
AWS_REGION=us-east-1
AWS_S3_BUCKET=replace-with-existing-or-new-bucket
S3_PREFIX=prod/
BACKUP_S3_URI=s3://replace-with-backup-bucket/interview-app/db

# Prefer an IAM role if available. On Lightsail, use a narrow IAM user only for
# the required S3 bucket actions.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google OAuth; leave empty only if email/password login is enough.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI providers. Set real keys if production flows need AI evaluation/transcribe.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
