{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".integration.spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/test/integration-env.ts"],
  "globalSetup": "<rootDir>/test/integration-global-setup.ts",
  "testTimeout": 60000,
  "maxWorkers": 1
}
