# Copy to ".env" for local development (never commit ".env").
# Docker Compose exposes Postgres on host port 5433 and MinIO S3 API on 9002.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://interview_app:localpass@localhost:5433/interview_app_dev

# Any long random string for local use; match production only if you share cookies with cloud (you do not).
JWT_SECRET=change-me-local-dev-only

FRONTEND_URL=http://localhost:3001

AWS_S3_BUCKET=interview-app-local
S3_PREFIX=dev/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9002
S3_FORCE_PATH_STYLE=true

# Leave empty to skip Google login locally, or paste OAuth client credentials from Google Cloud / team vault.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Comma-separated list; these emails can be treated as super_admin when roles sync.
SUPER_ADMIN_EMAILS=admin@interview-app.com

# Optional AI — AI_API_URL (legacy proxy) or AI_PROVIDER + API key below
# AI_API_URL=

# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# AI_PROVIDER=google
# GOOGLE_AI_API_KEY=
# GOOGLE_AI_MODEL=gemini-2.5-flash-lite
